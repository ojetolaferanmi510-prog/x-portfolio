# Server
NODE_ENV=development
PORT=5000

# Comma-separated allowed browser origins (CORS)
# Local Live Server + production Vercel example:
CLIENT_URL=http://localhost:5500,http://127.0.0.1:5500

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Admin seed (npm run seed:admin) — password min 8 chars
ADMIN_USER=admin
ADMIN_PASS=change-me-strong-password

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=portfolio

# Resend (contact form notify — optional but recommended)
RESEND_API_KEY=
EMAIL_FROM=Portfolio <onboarding@resend.dev>
EMAIL_TO=you@example.com
